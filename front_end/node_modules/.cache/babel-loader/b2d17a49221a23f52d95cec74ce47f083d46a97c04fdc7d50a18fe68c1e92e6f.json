{"ast":null,"code":"export const storageService={get:function(key){let fallback=arguments.length>1&&arguments[1]!==undefined?arguments[1]:null;try{const value=localStorage.getItem(key);return value?JSON.parse(value):fallback;}catch(error){return fallback;}},set:(key,value)=>{localStorage.setItem(key,JSON.stringify(value));},remove:key=>{localStorage.removeItem(key);}};","map":{"version":3,"names":["storageService","get","key","fallback","arguments","length","undefined","value","localStorage","getItem","JSON","parse","error","set","setItem","stringify","remove","removeItem"],"sources":["D:/Lap_Trinh_Web/Du_An_Ca_Nhan/DuAnWebBanSach/front_end/src/services/storageService.js"],"sourcesContent":["export const storageService = {\r\n  get: (key, fallback = null) => {\r\n    try {\r\n      const value = localStorage.getItem(key);\r\n      return value ? JSON.parse(value) : fallback;\r\n    } catch (error) {\r\n      return fallback;\r\n    }\r\n  },\r\n  set: (key, value) => {\r\n    localStorage.setItem(key, JSON.stringify(value));\r\n  },\r\n  remove: (key) => {\r\n    localStorage.removeItem(key);\r\n  },\r\n};\r\n"],"mappings":"AAAA,MAAO,MAAM,CAAAA,cAAc,CAAG,CAC5BC,GAAG,CAAE,QAAAA,CAACC,GAAG,CAAsB,IAApB,CAAAC,QAAQ,CAAAC,SAAA,CAAAC,MAAA,IAAAD,SAAA,MAAAE,SAAA,CAAAF,SAAA,IAAG,IAAI,CACxB,GAAI,CACF,KAAM,CAAAG,KAAK,CAAGC,YAAY,CAACC,OAAO,CAACP,GAAG,CAAC,CACvC,MAAO,CAAAK,KAAK,CAAGG,IAAI,CAACC,KAAK,CAACJ,KAAK,CAAC,CAAGJ,QAAQ,CAC7C,CAAE,MAAOS,KAAK,CAAE,CACd,MAAO,CAAAT,QAAQ,CACjB,CACF,CAAC,CACDU,GAAG,CAAEA,CAACX,GAAG,CAAEK,KAAK,GAAK,CACnBC,YAAY,CAACM,OAAO,CAACZ,GAAG,CAAEQ,IAAI,CAACK,SAAS,CAACR,KAAK,CAAC,CAAC,CAClD,CAAC,CACDS,MAAM,CAAGd,GAAG,EAAK,CACfM,YAAY,CAACS,UAAU,CAACf,GAAG,CAAC,CAC9B,CACF,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}